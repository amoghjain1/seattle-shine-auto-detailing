# Public site URL (used for metadata / Open Graph). On Vercel, set to your production domain.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Contact form — https://resend.com
# With onboarding@resend.dev, Resend only delivers to your Resend account email;
# the app skips customer replyTo in that mode. Verify a domain + use a matching
# RESEND_FROM_EMAIL for production (then reply-to the customer works).
RESEND_API_KEY=
RESEND_FROM_EMAIL=Seattle Shine <onboarding@resend.dev>
CONTACT_TO_EMAIL=seattleshine1@gmail.com

# Instagram Graph API (Business/Creator account + Facebook Page)
# GET /{ig-user-id}/media — see Meta developer docs for token setup.
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# Manual gallery (no Meta app). Leave INSTAGRAM_ACCESS_TOKEN and INSTAGRAM_USER_ID empty
# so this is used. Put JPEGs/PNGs in public/gallery/ and use root-relative URLs.
# Vercel: paste as one line (no line breaks). Escape double quotes if your editor requires it.
#
# Example (minified):
# INSTAGRAM_STATIC_GALLERY_JSON=[{"id":"mercedes-glc-before","mediaType":"IMAGE","mediaUrl":"/gallery/mercedes-glc-interior-before.png","thumbnailUrl":"/gallery/mercedes-glc-interior-before.png","permalink":"https://www.instagram.com/seattleshinewa/","caption":"Mercedes GLC interior before detail"},{"id":"mercedes-glc-after","mediaType":"IMAGE","mediaUrl":"/gallery/mercedes-glc-interior-after.png","thumbnailUrl":"/gallery/mercedes-glc-interior-after.png","permalink":"https://www.instagram.com/seattleshinewa/","caption":"Mercedes GLC interior after detail"}]
#
# mediaType: IMAGE | VIDEO | CAROUSEL_ALBUM — for VIDEO set thumbnailUrl to a poster image.
# Remote URLs work only for hosts in next.config.ts (e.g. *.cdninstagram.com, images.unsplash.com).
INSTAGRAM_STATIC_GALLERY_JSON=
